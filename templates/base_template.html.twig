<!DOCTYPE html>
<html lang="{{ constantes.application.language }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ constantes.application.website_name }}{% endblock %}</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="CSS/style.css">
    <link rel="shortcut icon" type="image/x-icon" href="wailordpixel.png"/>
</head>

<style>
    .footer-credits {
    background-color: #f8f9fa;
    box-shadow: 0 -2px 6px rgba(0, 0, 0, 0.06);
    padding: 0.75rem 1rem;
    margin-top: auto;
    font-size: 0.82rem;
    color: var(--text-main);
}

.footer-label {
    color: #6c757d;
    white-space: nowrap;
}

.footer-label .bi-heart-fill {
    color: var(--accent-color);
}

.footer-sep {
    color: #dee2e6;
}

.footer-dev {
    cursor: default;
    white-space: nowrap;
}

.footer-dev i {
    color: var(--accent-color);
}

.footer-desc {
    font-size: 0.73rem;
    color: #6c757d;
    font-style: italic;
    margin-left: 0.3rem;
}

.footer-wailord-img {
    width: 0.9rem;
    height: 0.9rem;
    object-fit: contain;
    image-rendering: pixelated;
    vertical-align: middle;
}
</style>

    <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4 shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="?">
                <i class="bi bi-film me-2"></i>{{ constantes.application.website_name }}
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav ms-auto">
                    {% if user is defined %}
                        <li class="nav-item">
                            <a class="nav-link" href="?controleur=profil">
                                <i class="bi bi-person me-1"></i>{{ user }}
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-danger" href="?controleur=auth&logout=1">
                                <i class="bi bi-box-arrow-right me-1"></i>Déconnexion
                            </a>
                        </li>
                    {% endif %}
                </ul>
            </div>
        </div>
    </nav>

<body>
    <div class="container main-content" style="max-width: 900px;">
        {% block body %}{% endblock %}
    </div>

    <footer class="footer-credits">
        <div class="container d-flex justify-content-center align-items-center gap-3">
            <span class="footer-label"><i class="bi bi-heart-fill me-1"></i>Développé avec amour par</span>
            <span class="footer-sep">—</span>
            <span class="footer-dev">
                <i class="bi bi-cookie me-1"></i><strong>Coukie_man</strong>
                <span class="footer-desc">naine à ses heures perdues</span>
            </span>
            <span class="footer-sep">·</span>
            <span class="footer-dev">
                <i class="bi bi-lightning-charge me-1"></i><strong>TheAtomic</strong>
                <span class="footer-desc">100% non-toxique certifié par lui-même</span>
            </span>
            <span class="footer-sep">·</span>
            <span class="footer-dev">
                <img src="wailordpixel.png" class="footer-wailord-img me-1" alt="Wailord"><strong>Wailord</strong>
                <span class="footer-desc">notre seigneur bleu de 14.5m, il n'a pas codé mais on lui doit tout</span>
            </span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="JS/script.js"></script>
    <script>document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => new bootstrap.Tooltip(el));</script>
</body>
</html>