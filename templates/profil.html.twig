{% extends 'base_template.html.twig' %}
{% block title %}Mon profil — {{ user }}{% endblock %}

{% block body %}

<header class="text-center mb-5">
    <h1 class="display-4">
        <i class="bi bi-person-circle me-2"></i>{{ user }}
    </h1>
</header>

{% if messages is not empty %}
    <div class="alert alert-info border-0 shadow-sm mt-3 mb-4">
        <i class="bi bi-info-circle-fill me-2"></i>
        {% for msg in messages %}
            <span class="ms-4">{{ msg }}</span><br>
        {% endfor %}
    </div>
{% endif %}

{# Upload CSV #}
<div class="card p-4 mb-4 upload-section">
    <h2 class="h5 mb-4 border-bottom pb-2 text-uppercase" style="letter-spacing: 1px;">
        <i class="bi bi-cloud-arrow-up me-2"></i>Mettre à jour mes données
    </h2>
    <form method="POST" enctype="multipart/form-data">
        <input type="hidden" name="upload_action" value="1">
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label fw-bold small">Watched (CSV)</label>
                <input type="file" name="watched" class="form-control form-control-sm">
            </div>
            <div class="col-md-6">
                <label class="form-label fw-bold small">Watchlist (CSV)</label>
                <input type="file" name="watchlist" class="form-control form-control-sm">
            </div>
        </div>
        <button type="submit" class="btn btn-primary mt-3">
            <i class="bi bi-upload me-2"></i>Mettre à jour
        </button>
    </form>
</div>

{# Groupe / Amis #}
<div class="card p-4 mb-4">
    <h2 class="h5 mb-4 border-bottom pb-2 text-uppercase" style="letter-spacing: 1px;">
        <i class="bi bi-people me-2"></i>Mon groupe
        <span class="text-muted small fw-normal ms-2" style="letter-spacing: 0;">
            Choisis avec qui tu veux utiliser la roulette
        </span>
    </h2>
    <form method="POST">
        <input type="hidden" name="save_friends" value="1">
        <div class="row g-3">
            {% for u in all_users %}
                {% if u != user %}
                    <div class="col-6 col-md-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox"
                                   name="friends[]" value="{{ u }}"
                                   id="friend_{{ u }}"
                                   {% if u in friends %}checked{% endif %}>
                            <label class="form-check-label" for="friend_{{ u }}">{{ u }}</label>
                        </div>
                    </div>
                {% endif %}
            {% endfor %}
        </div>
        <button type="submit" class="btn btn-primary mt-4">
            <i class="bi bi-check-circle me-2"></i>Enregistrer
        </button>
    </form>
</div>

{# Changer mot de passe #}
<div class="card p-4 mb-4">
    <h2 class="h5 mb-4 border-bottom pb-2 text-uppercase" style="letter-spacing: 1px;">
        <i class="bi bi-key me-2"></i>Changer mon mot de passe
    </h2>
    <form method="POST">
        <input type="hidden" name="change_password" value="1">
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label fw-bold small">Ancien mot de passe</label>
                <input type="password" name="ancien_mdp" class="form-control form-control-sm" required>
            </div>
            <div class="col-md-4">
                <label class="form-label fw-bold small">Nouveau mot de passe</label>
                <input type="password" name="nouveau_mdp" class="form-control form-control-sm" required>
            </div>
            <div class="col-md-4">
                <label class="form-label fw-bold small">Confirmer</label>
                <input type="password" name="confirm_mdp" class="form-control form-control-sm" required>
            </div>
        </div>
        <div class="text-muted small">
            On sinon tu demandes à Naïa parce que t un gros neuil
        </div>
        <button type="submit" class="btn btn-warning mt-3">
            <i class="bi bi-shield-lock me-2"></i>Changer
        </button>
    </form>
</div>

{# Watchlist #}
<div class="card p-4 mb-4">
    <h2 class="h5 mb-4 border-bottom pb-2 text-uppercase" style="letter-spacing: 1px;">
        <i class="bi bi-bookmark-heart me-2"></i>Ma Watchlist
        <span class="badge bg-secondary ms-2">{{ watchlist|length }}</span>
    </h2>

    {% if watchlist is not empty %}
    {# Barre filtres watchlist #}
    <div class="d-flex flex-wrap gap-2 mb-3 align-items-center">
        <div class="input-group input-group-sm" style="max-width: 260px;">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input type="text" class="form-control" id="search-watchlist" placeholder="Rechercher un film...">
        </div>
        <select class="form-select form-select-sm" id="sort-watchlist" style="max-width: 200px;">
            <option value="date-desc">Date ajout (récent → ancien)</option>
            <option value="date-asc">Date ajout (ancien → récent)</option>
            <option value="alpha-asc">Titre (A → Z)</option>
            <option value="alpha-desc">Titre (Z → A)</option>
            <option value="year-desc">Année (récent → ancien)</option>
            <option value="year-asc">Année (ancien → récent)</option>
        </select>
        <span class="text-muted small" id="watchlist-visible-count"></span>
    </div>
    {% endif %}

    {% if watchlist is empty %}
        <p class="text-muted fst-italic">Aucun film dans ta watchlist.</p>
    {% else %}
        <div style="max-height: 350px; overflow-y: auto;">
            <ul class="list-group list-group-flush" id="watchlist-list">
                {% for film in watchlist %}
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0 film-item"
                        data-title="{{ film.title|lower }}"
                        data-year="{{ film.year }}"
                        data-date="{{ film.date }}">
                        <div>
                            <span>{{ film.title }}</span>
                            <span class="text-muted small ms-2">{{ film.year }}</span>
                        </div>
                        <div class="d-flex gap-2 align-items-center">
                            <button class="btn btn-success btn-sm btn-vu"
                                data-title="{{ film.title }}"
                                data-url="{{ film.url }}">
                                <i class="bi bi-check2-circle me-1"></i>Vu
                            </button>
                            <a href="{{ film.url }}" target="_blank" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-box-arrow-up-right"></i>
                            </a>
                        </div>
                    </li>
                {% endfor %}
            </ul>
        </div>
        <p class="text-muted fst-italic mt-2" id="watchlist-empty-msg" style="display:none;">Aucun film ne correspond à ta recherche.</p>
    {% endif %}
</div>

{# Films vus #}
<div class="card p-4 mb-5">
    <h2 class="h5 mb-4 border-bottom pb-2 text-uppercase" style="letter-spacing: 1px;">
        <i class="bi bi-eye me-2"></i>Films vus
        <span class="badge bg-secondary ms-2">{{ watched|length }}</span>
    </h2>

    {% if watched is not empty %}
    {# Barre filtres watched #}
    <div class="d-flex flex-wrap gap-2 mb-3 align-items-center">
        <div class="input-group input-group-sm" style="max-width: 260px;">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input type="text" class="form-control" id="search-watched" placeholder="Rechercher un film...">
        </div>
        <select class="form-select form-select-sm" id="sort-watched" style="max-width: 200px;">
            <option value="date-desc">Date ajout (récent → ancien)</option>
            <option value="date-asc">Date ajout (ancien → récent)</option>
            <option value="alpha-asc">Titre (A → Z)</option>
            <option value="alpha-desc">Titre (Z → A)</option>
            <option value="year-desc">Année (récent → ancien)</option>
            <option value="year-asc">Année (ancien → récent)</option>
        </select>
        <span class="text-muted small" id="watched-visible-count"></span>
    </div>
    {% endif %}

    {% if watched is empty %}
        <p class="text-muted fst-italic">Aucun film vu enregistré.</p>
    {% else %}
        <div style="max-height: 350px; overflow-y: auto;">
            <ul class="list-group list-group-flush" id="watched-list">
                {% for film in watched %}
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0 film-item"
                        data-title="{{ film.title|lower }}"
                        data-year="{{ film.year }}"
                        data-date="{{ film.date }}">
                        <div>
                            <span>{{ film.title }}</span>
                            <span class="text-muted small ms-2">{{ film.year }}</span>
                        </div>
                        <a href="{{ film.url }}" target="_blank" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-box-arrow-up-right"></i>
                        </a>
                    </li>
                {% endfor %}
            </ul>
        </div>
        <p class="text-muted fst-italic mt-2" id="watched-empty-msg" style="display:none;">Aucun film ne correspond à ta recherche.</p>
    {% endif %}
</div>
<script src="JS/trier.js"></script>
{% endblock %}