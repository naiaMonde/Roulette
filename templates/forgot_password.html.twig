{% extends 'base_template.html.twig' %}
{% block title %}Mot de passe oublié{% endblock %}

{% block body %}

<header class="text-center mb-5">
    <h1 class="display-4">
        <i class="bi bi-key me-2"></i>Mot de passe oublié
    </h1>
    <p class="text-muted">Entrez votre pseudo et votre adresse email pour recevoir un lien de réinitialisation</p>
</header>

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card p-4">

            {% if success is defined %}
                <div class="alert alert-success border-0 shadow-sm">
                    <i class="bi bi-check-circle me-2"></i>{{ success }}
                </div>
                <a href="?controleur=auth" class="btn btn-outline-primary w-100 mt-2">
                    <i class="bi bi-arrow-left me-2"></i>Retour à la connexion
                </a>
            {% else %}

                {% if error is defined %}
                    <div class="alert alert-warning border-0 shadow-sm mb-3">
                        <i class="bi bi-exclamation-triangle me-2"></i>{{ error }}
                    </div>
                {% endif %}

                <form method="POST" action="?controleur=reset">
                    <input type="hidden" name="forgot_action" value="1">

                    <div class="mb-3">
                        <label class="form-label fw-bold small text-uppercase" style="letter-spacing: 1px;">Pseudo</label>
                        <input type="text" name="pseudo" class="form-control" required autofocus>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold small text-uppercase" style="letter-spacing: 1px;">Adresse email</label>
                        <input type="email" name="email" class="form-control" required>
                        <div class="form-text">L'email associé à votre compte.</div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-send me-2"></i>Envoyer le lien
                    </button>
                </form>

                <div class="text-center mt-3">
                    <a href="?controleur=auth" class="text-muted small">
                        <i class="bi bi-arrow-left me-1"></i>Retour à la connexion
                    </a>
                </div>

            {% endif %}

        </div>
    </div>
</div>

{% endblock %}
