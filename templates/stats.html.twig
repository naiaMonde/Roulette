{% extends 'base_template.html.twig' %}

{% block title %}Stats — {{ constantes.application.website_name }}{% endblock %}

{% block body %}

<header class="text-center mb-5">
    <h1 class="display-4"><i class="bi bi-bar-chart-line me-2"></i> Statistiques</h1>
    <p class="text-muted">Sélectionne des participants pour voir leurs stats de watchlist</p>
</header>
<style>
/* ── Stats page ── */
.stats-tabs-header {
    display: flex;
    border-bottom: 2px solid #ede8e2;
    padding: 0 8px;
    gap: 0;
}

.stats-tab-btn {
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    padding: 12px 18px;
    font-size: .85rem;
    font-weight: 600;
    color: #aaa;
    cursor: pointer;
    transition: color .15s, border-color .15s;
    letter-spacing: .3px;
    white-space: nowrap;
}

.stats-tab-btn:hover {
    color: var(--accent-color);
}

.stats-tab-btn.active {
    color: var(--accent-color);
    border-bottom-color: var(--accent-color);
}

.stats-big-number {
    font-family: 'Playfair Display', serif;
    font-size: 4rem;
    font-weight: 700;
    color: var(--accent-color);
    line-height: 1;
}

.stats-film-list .list-group-item {
    border-left: none;
    border-right: none;
    padding: 10px 4px;
}

.stats-film-list .list-group-item:first-child {
    border-top: none;
}

.film-title-stat {
    font-size: .9rem;
    color: var(--text-main);
}

.stat-badge,
.stat-badge-vus {
    font-size: .75rem;
    min-width: 36px;
}

.stat-badge {
    background-color: var(--accent-color);
}

.stat-badge-vus {
    background-color: #5d6d31;
}

.dot {
    font-size: .7rem;
    line-height: 1;
}

.dot-filled {
    color: var(--accent-color);
}

.dot-empty {
    color: #ccc;
}

.decade-label {
    font-weight: 700;
    font-size: .85rem;
    color: var(--text-main);
    letter-spacing: .5px;
}

.decade-legend {
    display: inline-block;
    width: 12px;
    height: 12px;
    border-radius: 3px;
    margin-right: 5px;
    vertical-align: middle;
}

.recap-card {
    border: 1px solid var(--card-border);
    border-radius: 12px;
    padding: 16px 20px;
    background: #fdfaf5;
}

.recap-name {
    font-weight: 600;
    font-size: .95rem;
    margin-bottom: 10px;
    color: var(--text-main);
}

.recap-stats {
    display: flex;
    gap: 16px;
    font-size: .875rem;
    color: #666;
</style>
{# --- PARTICIPANTS --- #}
<div class="card p-4 mb-4">
    <h2 class="h5 mb-3 border-bottom pb-2 text-uppercase" style="letter-spacing: 1px;">
        <i class="bi bi-people me-2"></i> Participants
    </h2>
    <div class="row g-3">
        {% for user in users %}
            <div class="col-6 col-md-3">
                <div class="form-check">
                    <input
                        class="form-check-input participant-check"
                        type="checkbox"
                        value="{{ user }}"
                        id="stat_{{ user }}"
                    >
                    <label class="form-check-label fw-semibold" for="stat_{{ user }}">
                        <i class="bi bi-person-circle me-1 text-muted"></i>{{ user }}
                    </label>
                </div>
            </div>
        {% endfor %}
    </div>
</div>

{# --- STATS (rempli par JS) --- #}
<div id="stats-card"></div>

{% endblock %}

{% block extra_scripts %}
<script src="JS/stats.js"></script>
{% endblock %}
