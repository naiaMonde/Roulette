{% extends 'base_template.html.twig' %}
{% block title %}Réinitialiser le mot de passe{% endblock %}

{% block body %}

<header class="text-center mb-5">
    <h1 class="display-4">
        <i class="bi bi-shield-lock me-2"></i>Nouveau mot de passe
    </h1>
    <p class="text-muted">Choisissez un nouveau mot de passe pour votre compte</p>
</header>

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card p-4">

            {% if error is defined %}
                <div class="alert alert-warning border-0 shadow-sm mb-3">
                    <i class="bi bi-exclamation-triangle me-2"></i>{{ error }}
                </div>
            {% endif %}

            <form method="POST" action="?controleur=reset">
                <input type="hidden" name="reset_action" value="1">
                <input type="hidden" name="token" value="{{ token }}">

                <div class="mb-3">
                    <label class="form-label fw-bold small text-uppercase" style="letter-spacing: 1px;">Nouveau mot de passe</label>
                    <input type="password" name="mdp" class="form-control" required autofocus>
                    <div class="form-text">6 caractères minimum.</div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold small text-uppercase" style="letter-spacing: 1px;">Confirmer</label>
                    <input type="password" name="confirm" class="form-control" required>
                </div>

                <button type="submit" class="btn btn-success w-100">
                    <i class="bi bi-check-circle me-2"></i>Enregistrer le mot de passe
                </button>
            </form>

        </div>
    </div>
</div>

{% endblock %}
